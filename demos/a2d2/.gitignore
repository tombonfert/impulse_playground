# Never commit any A2D2 dataset content or derived data.
# The A2D2 dataset is CC BY-ND 4.0 (NoDerivatives) — it must not be redistributed.
# The ingestion notebook downloads it at runtime into your own workspace.
data/
*.tar
*.json
**/*.png
**/*.mp4
# DABs build artifacts (the impulse wheel lives in demos/a2d2/dist/)
/dist/
.databricks/
# Frontend build output MUST ship with the app (served by FastAPI from frontend/dist).
!app/frontend/dist/
!app/frontend/dist/**
# Never commit node_modules / python venv.
app/frontend/node_modules/
app/.venv/
